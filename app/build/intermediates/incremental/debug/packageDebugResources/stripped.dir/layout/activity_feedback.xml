<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSendFeedback"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvFeedbackTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feedback_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFeedbackSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feedback_subtitle"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- RPE Items: 0 a 10 -->
            <!-- 0 – Muito Fácil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe0"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😄  0 - Muito Fácil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe1"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="🙂  1"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 2 – Fácil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😊  2 - Fácil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe3"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😐  3"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 4 – Um pouco fácil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe4"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😑  4 - Um pouco fácil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe5"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😮  5"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 6 – Um pouco difícil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe6"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😓  6 - Um pouco difícil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 7 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe7"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😰  7"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 8 – Difícil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe8"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😩  8 - Difícil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 9 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe9"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="😤  9"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 10 – Muito Difícil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRpe10"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_light">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="🥵  10 - Muito difícil"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Botão Enviar fixo no bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendFeedback"
        style="@style/Widget.FitnessMVP.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:text="@string/send_feedback"
        android:enabled="false"
        android:alpha="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
