    <style name="DayHeaderLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="Theme.FitnessMVP" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/bg_white</item>
    </style>
    <style name="Theme.FitnessMVP.Dashboard" parent="Theme.FitnessMVP">
        <item name="android:statusBarColor">@color/bg_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="Theme.FitnessMVP.RestActivity" parent="Theme.FitnessMVP">
        <item name="android:statusBarColor">@color/bg_white</item>
    </style>
    <style name="Widget.FitnessMVP.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/danger_red</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="Widget.FitnessMVP.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    <style name="Widget.FitnessMVP.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/primary_blue</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="Widget.FitnessMVP.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
